{
  "name": "v79-tick-it",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite --port=5174 --host=0.0.0.0\"",
    "server": "node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "stop:prod": "pm2 stop ecosystem.config.cjs",
    "restart:prod": "pm2 restart ecosystem.config.cjs",
    "logs:prod": "pm2 logs v79-tickit-backend",
    "build": "vite build",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "backup": "node scripts/backup-db.js",
    "generate-secrets": "node scripts/generate-secrets.js"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@greatsumini/react-facebook-login": "^3.4.0",
    "@react-oauth/google": "^0.12.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "apple-signin-auth": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "autoprefixer": "^10.4.21",
    "puppeteer": "^25.0.2",
    "tailwindcss": "^4.1.14",
    "terser": "^5.47.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
